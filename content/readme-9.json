":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"把各种经管理论落地，以数字化的系统连接和打通。","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"dm1xLVCDsI"}],"key":"q8O5YvlCQp"}],"key":"tg3avllPqe"},{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"系统工程的观点去做","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"I2hDa4IjEC"}],"key":"KOIUIwAES4"}],"key":"Tj9duYCJye"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"作为其他合作伙伴的胶水。承担实际上的牵头作用。","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"WPsLsDh6Uo"}],"key":"oRf20UgHF1"}],"key":"nrq38pJIiA"}],"key":"UXo3uv6vON"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"具体到一些大项目：","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"pr806vhihB"}],"key":"GCoTZlbDEM"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":15,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"我们自己，接了以后分包。","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"ZWMwYkDaqX"}],"key":"wLvK1XRMwh"}],"key":"eJRznmYy4w"},{"type":"listItem","spread":true,"position":{"start":{"line":16,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"其他人，解决不了以后找我们拆包。","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"q8lxsz9wdl"}],"key":"CgrDtmqS4N"}],"key":"bNpT7asz2N"}],"key":"rwDN6iJm1W"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"我们需要：","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"gnn2rw4Wr6"}],"key":"QB6T9BJzN0"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":19,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"尽可能公开，以换取这样的粘合角色。","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"qpctyDyuqQ"}],"key":"MnvVMWUqOB"}],"key":"HYrv0Ursh1"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"保持组织协调和制度设计能力，也就是持续地发展经管学术能力及产学研转化。","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"wIkkUwKI8G"}],"key":"r2EPcGTLYL"}],"key":"WEyLpWWHW6"}],"key":"cr3P3yRlJV"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"如何协调利益？\n科斯定理。外部性或者非效率通过谈判纠正。","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"iPHjgYJLvd"}],"key":"RiWXf8FInd"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"比如说，一家给另一家主导的开源项目贡献更多不满意了，两家可以商谈以后重新协商如何分配资源。\n通过这种方式让创业公司成群抱团，形成大公司才有的竞争力。但是由于这其中又都是市场谈判的，整体比大公司效率高，这样整个系统的竞争力就强。","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"oqPL3yIxHu"}],"key":"wwQKXlXLFK"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"如何构造这个系统，量潮在这个系统为什么是关键角色。我们如何通过持股等很多方式来粘合大家。","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"HGXXVij9cw"}],"key":"owidpOMJGu"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Inspired by 我同学创业公司的工作室群抱团的思路。","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"GopuhbzLSV"}],"key":"sF5KYm3DnA"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"我们承担了设计整个行业和各个公司战略（经济咨询），以及组织管理整个社区、给各家输出管理经验（云和课程），让各家CEO和团队可以专注在自己的方向，而我们可以给大家保驾护航。","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"PfCCW9lSEy"}],"key":"Fp50pIO6YW"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"我们这里需要把云输出。合作的时候可以约定边界，各自不去做其他家做的云来抢市场。当然实际上也做不了。通过合约去保障，形成一个同盟关系。","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"OB7aQRxDkt"}],"key":"IDP9i8MfPz"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"课程方面，主要是基础课对于其他合作者来说也不是那么的有效，所以可以以合作上架的形式来，也是通过谈判来分配利益。课程研发和教学工作的联合模型，量潮课堂主要提供平台和一般的基础课，其他的都需要依赖内部其他单元或者外部合作伙伴来做。定向培养可以收钱。这样课程业务的大客户也有了。","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"ywI83VC2Ij"}],"key":"wKIy4RNY7f"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"要尽可能在体系内透明公开，并且要尽量多总结其中的经验。形成一个行业联盟。","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"fowTGjmCFN"}],"key":"gWbiyQ6aLf"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"人力资源也是个问题，大家怎么协调抢人的事情，而且还要和外部竞争。简单的说是尽量把人留在这个体系内流动，这样大家可以共建，以我们的课程业务为初级人才的核心。高级主要是通过兼职来解决。协调兼职的利益。","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"iEFTfIG2mY"}],"key":"xkLmhPcO5O"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"我总感觉到我的思路里隐含了很多经济学原理，但是我没有办法很清晰地阐述出来。我需要首先阐述清楚定性的战略思路和经济学原理，然后把具体问题拿去和经管学术圈讨论，从而尽可能获得结果。","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"Pgu6npl5uF"}],"key":"k0zYdqSZ0V"}],"key":"JtYjLCQ7Wp"}],"key":"vLBLMhpmu7"},"references":{"cite":{"order":[],"data":{}}}}
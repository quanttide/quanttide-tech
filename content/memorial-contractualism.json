配套工具与工作流，提升组织智慧的传承与进化效率。","position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"key":"TfbgtpAMil"}],"key":"rg4wAvMO1u"},{"type":"heading","depth":3,"position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"记忆系统的交互机制","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"nVhFecCzHj"}],"identifier":"id","label":"记忆系统的交互机制","html_id":"id-10","implicit":true,"key":"NiTsHFRiXL"},{"type":"paragraph","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"陈述型记忆与程序型记忆并非孤立运作，而是通过特定路径相互转化。","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"xw20gYSYHg"}],"key":"wBQ89dbunJ"},{"type":"paragraph","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"strong","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"转化路径","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"wv7U1hoRdp"}],"key":"C6M65gb1fi"},{"type":"text","value":"：Journal（陈述型-现在-事件）中的重复性工作，经提炼成为 Usecase（程序型-L2），最终固化为 Specification（程序型-L4）。","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"H0EGSKr7mh"}],"key":"ohslrVFlb0"},{"type":"paragraph","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"strong","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"查询接口","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"eFEPfDwrJm"}],"key":"Yined1esA1"},{"type":"text","value":"：面对具体问题时，需要同时调用两个系统。例如，工程师既需查询 Specification 了解编码规范，也需参阅 Essay 理解技术选型的深层原因。","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"uFZkcd11kx"}],"key":"YH36zwOvVg"},{"type":"heading","depth":3,"position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"t
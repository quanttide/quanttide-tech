rRdagI17f"},{"type":"paragraph","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"信息数量和密度是倒金字塔，自下而上信息越少信息密度越大、约束力越强。","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"rMLbjB9eRj"}],"key":"VLw18v4yVl"},{"type":"paragraph","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"具体分类见 ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"DvO21XtbUr"},{"type":"link","url":"../../../profile/meta/memory_model.md","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"记忆模型简介","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"lnI2T8PobU"}],"urlSource":"../../../profile/meta/memory_model.md","key":"QWduOyPPsW"},{"type":"text","value":"。","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"jZC7ptTZgj"}],"key":"vQwrLuJ1uZ"},{"type":"heading","depth":3,"position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"陈述型记忆的价值","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"n6Ct7SM17j"}],"identifier":"id","label":"陈述型记忆的价值","html_id":"id-7","implicit":true,"key":"fO3IZHXfDh"},{"type":"paragraph","position":{"start":{"line":68,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"第一，它解决了知识管理的\"身份危机\"\n大多数知识管理框架只问\"这是什么类型的知识\"，而九宫格多问了一句：“这个知识对我们意味着什么？”","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"vEFkgFrLuB"}],"key":"ftTRJ7yZsd"},{"type":"paragraph","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"这三问，把知识管理从\"文件夹分类学\"变成了组织身份认同。","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"TdB04hui6g"}],"key":"vSJY2JdeWU"},{"type":"paragraph","position":{"start":{"line":73,"column":1},"end":{"
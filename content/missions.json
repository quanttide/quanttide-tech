{"version":3,"kind":"Article","sha256":"ec45fec630052904b1b4532addd39224c966ddde91a9fe18a69bf5d5a2db50c4","slug":"missions","location":"/archive/roadmap/governance/culture/missions.md","dependencies":[],"frontmatter":{"title":"使命","content_includes_title":false,"github":"https://github.com/quanttide/quanttide-tech","keywords":["quanttide","documentation"],"numbering":{"title":{"offset":4}},"source_url":"https://github.com/quanttide/quanttide-tech/blob/main/docs/archive/roadmap/governance/culture/missions.md","edit_url":"https://github.com/quanttide/quanttide-tech/edit/main/docs/archive/roadmap/governance/culture/missions.md","exports":[{"format":"md","filename":"missions.md","url":"/missions-09fb5d28c13066584b7d7acc92b163dc.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"我们的使命就是我们的Slogan——","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KnYIzLC8Op"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"引领定量分析时代潮流","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zX5uatw7ep"}],"key":"ApnOF7M6xQ"},{"type":"text","value":"。这句话有两个关键点，“定量分析”和“引领时代潮流”。我们将从这两个方面阐述我们的使命。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"m1Tg5VsLTd"}],"key":"uConh3irb4"},{"type":"heading","depth":2,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"定量分析","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"kunaME8yJm"}],"identifier":"id","label":"定量分析","html_id":"id","implicit":true,"key":"eyt0pXhMyy"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"定量分析是我们专精的领域。社会科学的","position":{"start":{"line":8,"column":1},"end":{"line":8,"colum
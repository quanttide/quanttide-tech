umn":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"法律的类型","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"f0iB50ddPf"}],"identifier":"id","label":"法律的类型","html_id":"id-2","implicit":true,"key":"QI7Dh7MVU8"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"习惯法、判例法和成文法。英美法和大陆法。","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"p7y9Qs5Mrd"}],"key":"LAJ8gbbfsp"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"效率和公平的权衡，不能够照抄各国机构，而是需要根据我们的实际情况改。彻底分离立法机构 司法机构 行政机构 并且搞三权分立是不现实的，也不一定适合公司治理，所以我们目前主要目标是定义清楚三权和三类机构，并且明确的规定其享受的权力。","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"kdf9sj5RxS"}],"key":"xAesAeLu70"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"以委员会为中心的“立法权”。分为“立法机构”和“行政机构”，对应“所有权代表机构”和“经营权代表机构”。","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"AnC5dmZcDA"}],"key":"T8FjUVXuJO"},{"type":"heading","depth":2,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"当前实践","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"wSYUr1ZznY"}],"identifier":"id","label":"当前实践","html_id":"id-3","implicit":true,"key":"egbZjp3vct"},{"type":"heading","depth":3,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"形式","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"qCrSzCpPRd"}],"identifier":"id","label":"形式","html_id":"id-4","implicit":true,"key":"tA2vnlHPvT"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"合伙人委员会行使股东大会、董事会、监事会的权限。\n合伙人委员会让渡大部分经营权给负责人委员会，保留一部分敏感和关键权限。","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"EaNdCRyX9E"}],"key":"oLfVaVedFP"},{"type":"heading","depth":3,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"对象","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"tBKXSxrhto"}],"identifier":"id","label":"对象","html_id":"id-5","implicit":true,"key":"FcurCrClbf"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"主要是以教程、手册、标准体系形成“习惯法”，不具备直接的强制约束力，不和劳务合同等人事、财务、法务绑定。","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"QGndidI4tT"}],"key":"jbSCbFz9Kf"},{"type":"heading","depth":3,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"原理","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"iPg4jgxTtA"}],"identifier":"id","label":"原理","html_id":"id-6","implicit":true,"key":"JfICDjmOkj"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"合伙人委员会体系和负责人委员会体系分别代表所有权和经营权，所有权体系通过执政党模型实际控制经营权体系。","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"UJzgnfDvPq"}],"key":"QH1WTZEj6j"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"分割立法权参考了美式的上下两院共享立法权的体系。负责人委员会的议政合一参考了英式下议院和内阁/苏式人民委员会的形式。","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"mOjjBF6twz"}],"key":"UaBWkTgIzy"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"目前编制的制度大多是惯例，并不是写到公司章程的正式制度。正式写章程既没有必要也没有条件。","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"SUgNrNVPZX"}],"key":"uwC6h2zNyn"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"立法机构直接掌握立法权的相关司法权。","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"evzT3AZaQZ"}],"key":"jg3v180Wz3"},{"type":"heading","depth":2,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"未来趋势","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"isL9LtWMPv"}],"identifier":"id","label":"未来趋势","html_id":"id-7","implicit":true,"key":"drNOR7YZn2"},{"type":"heading","depth":3,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"形式","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"JgrxhZwEL4"}],"identifier":"id","label":"形式","html_id":"id-8","implicit":true,"key":"VM5zkN1jaQ"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"合伙人委员会类比政治局、领导者委员会类比中央委员会。","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"WFGSnXwUNs"}],"key":"wdAL8s5BIH"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"股东大会和董事会类比人大和人大常委会。监事会类比政协，如果设立监事会。","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"MArXAFNqw6"}],"key":"h7TxnwIme4"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"管理层类比国务院，负责人常委会和负责人委员会类比国务院常务会议和国务院全体会议，专业委员会类比国务院议事协调机构。","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"LJLA0ffelt"}],"key":"nWDUxAz6mX"},{"type":"heading","depth":3,"position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"原则","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"TOuB7I1C7b"}],"identifier":"id","label":"原则","html_id":"id-9","implicit":true,"key":"Dx76ZDzhSr"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"在外部合作者加入内部体系以后，比如有投资人加入。立法权逐渐从经营权体系迁移到所有权体系，以激励这些利益相关方参与决策，进而利用他们的专业能力和社会资源。应用执政党模型控制具有法律效应的决策机构，以确保对立法权的控制权。经营权体系形式的临时立法权需要经过立法机构确认才能成为长期有效的正式制度。","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"zOM8KZMToY"}],"key":"sXtLB4n3KF"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"立法机构主要负责公司章程，惯例依然由行政机构的议事机构形式部分立法权。公司章程是宪法，立法机构的决定还需要一套配套的子章程来记录。","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"PgR60eNFOf"}],"key":"RXyMSgJbye"},{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"“行政法规\"向\"正式法律\"演化。主要是因为信息不对称，行政机构更熟悉业务，所以先形成\"行政法规”，再经过立法机构审议以后形成\"正式法律\"。","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"v9NP1UsvcR"}],"key":"KVmo72iMTr"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"text","value":"如果行政机构和立法机构发生分歧，以立法机构的决策为准。以形成立法机构对行政机构的实际控制。当然，这需要经过必要的辩论程序。","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"qkQUslM7wp"}],"key":"tUs7vAo8bF"}],"key":"ONNY9Nanmw"}],"key":"QeQHySBfUG"},"references":{"cite":{"order":[],"data":{}}}}
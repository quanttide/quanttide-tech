":1},"end":{"line":24,"column":1}},"key":"K17nmjA0Jp"}],"key":"RhAo9FGW9i"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"核心转变：从“个人扛”转向“系统扛”。","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"Utfh6vXRCd"}],"key":"YjdNeU094p"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"运作机制：利用第二大脑承接情绪，利用平台承接认知，利用制度承接责任。它将个人从“无限责任人”的位置上拉下来，让外部的工具、流程和团队成为承受压力的主体，从而实现个人的轻量化生存。","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"VF9QNyhrAk"}],"key":"auBD4eFo7i"},{"type":"heading","depth":2,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"一句话总结","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"Uue2SeCPlL"}],"identifier":"id","label":"一句话总结","html_id":"id-3","implicit":true,"key":"IFamBU8wwg"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"真正的身心健康，不是靠“扛得住”，而是靠“觉察得到（关怀）、守得住（精力）、扔得掉（系统）”。","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"Rb6y6gn3TZ"}],"key":"LmWh9PiyUf"}],"key":"q8n8K43eXb"}],"key":"Al40j2PRDC"},"references":{"cite":{"order":[],"data":{}}}}
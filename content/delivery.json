{"version":3,"kind":"Article","sha256":"c3ab9df2812adb37b2e0fd103147f145f410392cc1f9fd27c91cc3b24aba14ff","slug":"delivery","location":"/essay/qtdata/aseet/delivery.md","dependencies":[],"frontmatter":{"title":"定义量潮数据的交付规范","content_includes_title":false,"github":"https://github.com/quanttide/quanttide-tech","keywords":["quanttide","documentation"],"numbering":{"title":{"offset":3}},"source_url":"https://github.com/quanttide/quanttide-tech/blob/main/docs/essay/qtdata/aseet/delivery.md","edit_url":"https://github.com/quanttide/quanttide-tech/edit/main/docs/essay/qtdata/aseet/delivery.md","exports":[{"format":"md","filename":"delivery.md","url":"/delivery-5d37dd0e931756b9c87fc564266ed058.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最近又有一个项目进度失控了，上级链条也失效了。痛定思痛以后，我决定亲自救火。晚上疯狂写了一系列文档规范。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"iysVV82dkK"}],"key":"cOBGYvsQUF"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"写着写着，想到这不就是实验报告吗？于是打开了新世界的大门，拉上了我的基友毛导帮忙规范格式。","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"oL69RL79jJ"}],"key":"bQHgg1d0jY"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"产教融合的新视角：课堂反哺产业","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"jdTVfGqM8s"}],"identifier":"id","label":"产教融合的新视角：课堂反哺产业","html_id":"id","implicit":true,"key":"zJFbgRJr5Z"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"IT 课堂和产业虽然也有各种报告和规范一类的要求，但是规范程度是不够的，也不够约束一个充满了草台班子行为的团队。","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"g1NHXXdsek"}],"key":"CeoawX9vmu"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"理工科的实验规范和实验报告给了我们很好的启发。如果吸收理工科的方法规范交付要求和过程要求，则可以让管理团队和客户获得更透明的过程信息，以方便及时参与。","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"BpgCfJFms0"}],"key":"XB3YiggW4I"},{"type":"heading","depth":2,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"更新交付规范：透明化全过程","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"fYysHeCjk7"}],"identifier":"id","label":"更新交付规范：透明化全过程","html_id":"id-1","implicit":true,"key":"sKssEp1FYU"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"以我们定义的数据工程体系为核心，包括数据集、数据处理器（代码项目，交付可选）、数据工程文档。","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"X57p7piwTo"}],"key":"rV3FHZggwh"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"数据工程文档是这一轮规范的核心文档。包括数据模型定义、数据处理流程定义、数据集报告。在实施过程中需要持续更新文档，以确保最新信息及时被捕捉。","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"IrNOBb8s1z"}],"key":"rxHS8dgASr"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"此外，项目管理文档、报价单、合同等文档已经很早就纳入了我们的流程中，在设计和报价阶段就都会交付给客户。","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"jKFTT8yLtc"}],"key":"YooxTXjFN4"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"接下来计划为客户提供一系列完善的交付规范说明，通过公司账号发。","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"kBKEP9xhuf"}],"key":"Vp4aK7UzRy"}],"key":"iq2ok4FkK0"}],"key":"ncbBnkqKaQ"},"references":{"cite":{"order":[],"data":{}}}}